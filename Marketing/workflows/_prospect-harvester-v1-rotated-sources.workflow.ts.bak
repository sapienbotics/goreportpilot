const hunterFetch = node({ type: 'n8n-nodes-base.httpRequest', version: 4.4, config: { name: 'Hunter Fetch', parameters: { method: 'GET', url: expr('https://api.hunter.io/v2/domain-search?domain={{ $json.domain }}&type=personal&limit=3'), authentication: 'genericCredentialType', genericAuthType: 'httpQueryAuth', options: { response: { response: { responseFormat: 'json', neverError: true } }, timeout: 30000 } }, credentials: { httpQueryAuth: newCredential('Hunter API') }, alwaysOutputData: true, position: [2940, 500] }, output: [{ data: { emails: [{ value: 'jane@acme.com', first_name: 'Jane', last_name: 'Doe', position: 'CEO', linkedin: 'https://linkedin.com/in/janedoe' }] } }] });
const parseHunter = node({ type: 'n8n-nodes-base.code', version: 2, config: { name: 'Parse Hunter', parameters: { mode: 'runOnceForEachItem', language: 'javaScript', jsCode: "const meta = $('Parse Apollo').item.json;\nconst r = $input.item.json || {};\nconst data = r.data || {};\nconst emails = Array.isArray(data.emails) ? data.emails : [];\nlet pick = emails.find(e => e.position && /found|owner|ceo|principal/i.test(e.position)) || emails[0] || null;\nconst email = (pick && pick.value) || '';\nconst name = pick ? [pick.first_name, pick.last_name].filter(Boolean).join(' ') : '';\nconst linkedin = (pick && pick.linkedin) || '';\nreturn { ...meta, founder_name: meta.founder_name || name, email: email, linkedin_url: meta.linkedin_url || linkedin };" }, position: [3140, 500] }, output: [{ company: 'Acme', source: 'clutch', website: 'https://acme.com', country: 'US', employee_count: '10-49', services: 'PPC', domain: 'acme.com', founder_name: 'Jane Doe', email: 'jane@acme.com', linkedin_url: 'https://linkedin.com/in/janedoe' }] });
