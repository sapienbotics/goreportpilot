const parseScoreB = node({ type: 'n8n-nodes-base.code', version: 2, config: { name: 'Parse Score B', parameters: { mode: 'runOnceForEachItem', language: 'javaScript', jsCode: "const j = $input.item.json || {};\nlet raw = '';\nif (typeof j === 'string') raw = j;\nelse if (typeof j.content === 'string') raw = j.content;\nelse if (typeof j.text === 'string') raw = j.text;\nelse if (typeof j.output_text === 'string') raw = j.output_text;\nelse if (typeof j.output === 'string') raw = j.output;\nelse if (j.message && typeof j.message.content === 'string') raw = j.message.content;\nelse if (Array.isArray(j.output)) {\n  for (const o of j.output) { const cs = Array.isArray(o.content) ? o.content : (o.content ? [o.content] : []); for (const c of cs) { if (c && typeof c.text === 'string') raw += c.text; } }\n}\nif (!raw) raw = JSON.stringify(j);\nlet parsed = null;\ntry { parsed = JSON.parse(raw); } catch(e) { const m = raw.match(/\\{[\\s\\S]*\\}/); if (m) { try { parsed = JSON.parse(m[0]); } catch(_) {} } }\nif (!parsed || typeof parsed !== 'object') parsed = { fit_score: 5, signal_notes: 'parse_failed' };\nconst meta = $('Parse Hunter').item.json;\nreturn { ...meta, fit_score: parseInt(parsed.fit_score, 10) || 5, signal_notes: String(parsed.signal_notes || '').slice(0, 250) };" }, position: [3740, 500] }, output: [{ company: 'Acme', source: 'clutch', founder_name: 'Jane', email: 'jane@acme.com', linkedin_url: 'x', website: 'https://acme.com', country: 'US', employee_count: '10-49', services: 'PPC', fit_score: 6, signal_notes: 'partial' }] });
const shapeRowB = node({ type: 'n8n-nodes-base.set', version: 3.4, config: { name: 'Shape Prospect Row B', parameters: { mode: 'manual', assignments: { assignments: [{ id: 'pb1', name: 'company', value: expr('{{ $json.company }}'), type: 'string' }, { id: 'pb2', name: 'source', value: expr('{{ $json.source }}'), type: 'string' }, { id: 'pb3', name: 'founder_name', value: expr('{{ $json.founder_name }}'), type: 'string' }, { id: 'pb4', name: 'email', value: expr('{{ $json.email }}'), type: 'string' }, { id: 'pb5', name: 'linkedin_url', value: expr('{{ $json.linkedin_url }}'), type: 'string' }, { id: 'pb6', name: 'website', value: expr('{{ $json.website }}'), type: 'string' }, { id: 'pb7', name: 'country', value: expr('{{ $json.country }}'), type: 'string' }, { id: 'pb8', name: 'employee_count', value: expr('{{ $json.employee_count }}'), type: 'string' }, { id: 'pb9', name: 'services', value: expr('{{ $json.services }}'), type: 'string' }, { id: 'pb10', name: 'fit_score', value: expr('{{ $json.fit_score }}'), type: 'string' }, { id: 'pb11', name: 'signal_notes', value: expr('{{ $json.signal_notes }}'), type: 'string' }, { id: 'pb12', name: 'status', value: 'new', type: 'string' }, { id: 'pb13', name: 'date_added', value: expr('{{ $now.toISO() }}'), type: 'string' }] }, includeOtherFields: false }, position: [3940, 500] }, output: [{ company: 'Acme', source: 'clutch', founder_name: 'Jane', email: 'jane@acme.com', linkedin_url: 'x', website: 'https://acme.com', country: 'US', employee_count: '10-49', services: 'PPC', fit_score: '6', signal_notes: 'partial', status: 'new', date_added: '2026-04-26T00:30:00Z' }] });
const appendB = node({ type: 'n8n-nodes-base.googleSheets', version: 4.7, config: { name: 'Append Prospect B', parameters: { resource: 'sheet', operation: 'append', documentId: { __rl: true, mode: 'id', value: PROSPECT_PIPELINE_ID }, sheetName: { __rl: true, mode: 'name', value: PROSPECT_PIPELINE_TAB }, columns: { mappingMode: 'autoMapInputData', value: null, matchingColumns: [], schema: [], attemptToConvertTypes: false, convertFieldsToString: true }, options: { useAppend: true, handlingExtraData: 'ignoreIt' } }, credentials: { googleSheetsOAuth2Api: newCredential('Google Sheets') }, position: [4140, 500] }, output: [{ ok: true }] });
const shapeRunLog = node({ type: 'n8n-nodes-base.code', version: 2, config: { name: 'Shape Run Log Row', parameters: { mode: 'runOnceForAllItems', language: 'javaScript', jsCode: "function safeLen(name){ try { return $(name).all().length || 0; } catch(e){ return 0; } }\nfunction safeFirstJson(name){ try { return $(name).first().json || {}; } catch(e){ return {}; } }\nconst dedupMeta = safeFirstJson('Dedup Prospects');\nconst dayMeta = safeFirstJson('Day Router');\nconst apolloN = safeLen('Apollo Enrich');\nconst hunterN = safeLen('Hunter Fetch');\nconst scoreAN = safeLen('Score Prospect A');\nconst scoreBN = safeLen('Score Prospect B');\nconst appendAN = safeLen('Append Prospect A');\nconst appendBN = safeLen('Append Prospect B');\nconst added = appendAN + appendBN;\nconst attempted = (dedupMeta._meta_attempted ?? dedupMeta.prospects_attempted) || 0;\nconst dupes = (dedupMeta._meta_dupes ?? dedupMeta.duplicates_skipped) || 0;\nconst cost = ((scoreAN + scoreBN) * 0.0023).toFixed(4);\nlet status = 'success';\nif (attempted === 0) status = 'no_prospects_found';\nelse if (added === 0) status = 'no_new_prospects';\nreturn [{ json: {\n  date: new Date().toISOString(),\n  source: dayMeta.source || 'unknown',\n  prospects_attempted: String(attempted),\n  prospects_added: String(added),\n  duplicates_skipped: String(dupes),\n  apollo_credits_used: String(apolloN),\n  hunter_credits_used: String(hunterN),\n  openai_cost_usd: cost,\n  errors: '',\n  status: status\n} }];" }, position: [2340, 700] }, output: [{ date: '2026-04-26T00:30:00Z', source: 'clutch', prospects_attempted: '5', prospects_added: '4', duplicates_skipped: '1', apollo_credits_used: '5', hunter_credits_used: '1', openai_cost_usd: '0.0115', errors: '', status: 'success' }] });
const logRun = node({ type: 'n8n-nodes-base.googleSheets', version: 4.7, config: { name: 'Log Run', parameters: { resource: 'sheet', operation: 'append', documentId: { __rl: true, mode: 'id', value: HARVESTER_LOG_ID }, sheetName: { __rl: true, mode: 'name', value: HARVESTER_LOG_TAB }, columns: { mappingMode: 'autoMapInputData', value: null, matchingColumns: [], schema: [], attemptToConvertTypes: false, convertFieldsToString: true }, options: { useAppend: true, handlingExtraData: 'ignoreIt' } }, credentials: { googleSheetsOAuth2Api: newCredential('Google Sheets') }, position: [2540, 700] }, output: [{ ok: true }] });

export default workflow('grp-prospect-harvester', 'GRP - Prospect Harvester (Daily)')
  .add(trig)
  .to(dayRouter)
  .to(sourceSwitch
    .onCase(0, shapeSkipRow.to(logSkipped))
    .onCase(1, scrapeClutch.to(parseClutch.to(filterNormalize)))
    .onCase(2, scrapeMaps.to(parseMaps.to(filterNormalize)))
    .onCase(3, scrapeSortlist.to(scrapeSpotter.to(parseDirs.to(filterNormalize))))
  )
  .add(filterNormalize)
  .to(readExisting)
  .to(dedup)
  .to(noNewIf
    .onTrue(shapeRunLog)
    .onFalse(loop
      .onDone(shapeRunLog)
      .onEachBatch(
        apolloEnrich
          .to(parseApollo)
          .to(hasEmailIf
            .onTrue(scrapeWebA.to(scoreA).to(parseScoreA).to(shapeRowA).to(appendA).to(nextBatch(loop)))
            .onFalse(hunterFetch.to(parseHunter).to(scrapeWebB).to(scoreB).to(parseScoreB).to(shapeRowB).to(appendB).to(nextBatch(loop)))
          )
      )
    )
  )
  .add(shapeRunLog)
  .to(logRun);
